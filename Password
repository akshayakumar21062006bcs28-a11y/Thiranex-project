    cout << "  Strength : " << getStrengthLabel(score) << "\n";
    cout << "----------------------------------------\n";
    cout << "  CHECKS:\n";
    cout << "  [" << (pw.length() >= 8  ? "✓" : "✗") << "] At least 8 characters\n";
    cout << "  [" << (pw.length() >= 12 ? "✓" : "✗") << "] At least 12 characters\n";
    cout << "  [" << (hasUppercase(pw)  ? "✓" : "✗") << "] Uppercase letters (A-Z)\n";
    cout << "  [" << (hasLowercase(pw)  ? "✓" : "✗") << "] Lowercase letters (a-z)\n";
    cout << "  [" << (hasDigit(pw)      ? "✓" : "✗") << "] Numbers (0-9)\n";
    cout << "  [" << (hasSpecial(pw)    ? "✓" : "✗") << "] Special characters (!@#...)\n";
    cout << "  [" << (!hasRepeatedChars(pw) ? "✓" : "✗") << "] No repeated characters (aaa)\n";
    cout << "  [" << (!isCommonPassword(pw) ? "✓" : "✗") << "] Not a common password\n";
    cout << "----------------------------------------\n";
}

// ---------- Suggestion Generator ----------

void printSuggestions(const string& pw) {
    cout << "  SUGGESTIONS TO IMPROVE:\n";
    bool perfect = true;

    if (pw.length() < 12) {
        cout << "  → Use at least 12 characters for better security\n";
        perfect = false;
    }
    if (!hasUppercase(pw)) {
        cout << "  → Add uppercase letters (e.g., A, B, C)\n";
        perfect = false;
    }
    if (!hasLowercase(pw)) {
        cout << "  → Add lowercase letters (e.g., a, b, c)\n";
        perfect = false;
    }
    if (!hasDigit(pw)) {
        cout << "  → Add numbers (e.g., 1, 2, 3)\n";
        perfect = false;
    }
    if (!hasSpecial(pw)) {
        cout << "  → Add special characters (e.g., @, #, !)\n";
        perfect = false;
    }
    if (hasRepeatedChars(pw)) {
        cout << "  → Avoid repeating same character 3+ times\n";
        perfect = false;
    }
    if (isCommonPassword(pw)) {
        cout << "  → Avoid common passwords like 'password', '123456'\n";
        perfect = false;
    }
    if (perfect) {
        cout << "  ✅ Great password! No improvements needed.\n";
    }

    cout << "========================================\n";
}

// ---------- Strong Password Generator ----------

string generateStrongPassword(int length = 14) {
    string upper   = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    string lower   = "abcdefghijklmnopqrstuvwxyz";
    string digits  = "0123456789";
    string special = "!@#$%^&*()-_=+";
    string all     = upper + lower + digits + special;

    srand(time(0));
    string pw = "";
    // Ensure at least one of each type
    pw += upper[rand() % upper.size()];
    pw += lower[rand() % lower.size()];
    pw += digits[rand() % digits.size()];
    pw += special[rand() % special.size()];

    for (int i = 4; i < length; i++)
        pw += all[rand() % all.size()];

    // Shuffle the password
    for (int i = pw.size() - 1; i > 0; i--) {
        int j = rand() % (i + 1);
        swap(pw[i], pw[j]);
    }
    return pw;
}

