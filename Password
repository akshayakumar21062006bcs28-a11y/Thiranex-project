// ---------- Helper Functions ----------

bool hasUppercase(const string& pw) {
    for (char c : pw) if (isupper(c)) return true;
    return false;
}

bool hasLowercase(const string& pw) {
    for (char c : pw) if (islower(c)) return true;
    return false;
}

bool hasDigit(const string& pw) {
    for (char c : pw) if (isdigit(c)) return true;
    return false;
}

bool hasSpecial(const string& pw) {
    string special = "!@#$%^&*()-_=+[]{}|;:',.<>?/`~";
    for (char c : pw)
        if (special.find(c) != string::npos) return true;
    return false;
}

bool hasRepeatedChars(const string& pw) {
    for (int i = 0; i < (int)pw.size() - 2; i++)
        if (pw[i] == pw[i+1] && pw[i+1] == pw[i+2]) return true;
    return false;
}

bool isCommonPassword(const string& pw) {
    vector<string> common = {
        "password", "123456", "password123", "admin", "qwerty",
        "abc123", "letmein", "welcome", "monkey", "1234567890",
        "iloveyou", "sunshine", "princess", "dragon", "master"
    };
    string lower = pw;
    transform(lower.begin(), lower.end(), lower.begin(), ::tolower);
    for (const string& c : common)
        if (lower == c) return true;
    return false;
}

// ---------- Score Calculator ----------

int calculateScore(const string& pw) {
    int score = 0;

    // Length scoring
    int len = pw.length();
    if (len >= 8)  score += 10;
    if (len >= 12) score += 10;
    if (len >= 16) score += 10;

    // Character variety
    if (hasUppercase(pw)) score += 15;
    if (hasLowercase(pw)) score += 15;
    if (hasDigit(pw))     score += 15;
    if (hasSpecial(pw))   score += 20;

    // Penalties
    if (len < 6)              score -= 20;
    if (hasRepeatedChars(pw)) score -= 10;
    if (isCommonPassword(pw)) score -= 30;

    return max(0, min(score, 100));
}

// ---------- Strength Label ----------

string getStrengthLabel(int score) {
    if (score < 20)  return "Very Weak   ❌";
    if (score < 40)  return "Weak        ⚠️";
    if (score < 60)  return "Moderate    🔶";
    if (score < 80)  return "Strong      ✅";
    return               "Very Strong 🔒";
}

